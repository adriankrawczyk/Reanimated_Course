{
  "expo": {
    "name": "reanimated-course",
    "slug": "reanimated-course",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.reanimatedcourse"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-video"
    ],
    "ios": {
      "bundleIdentifier": "com.anonymous.reanimatedcourse"
    }
  }
}
